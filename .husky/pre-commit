#!/bin/sh

# Check for console.log/debug in staged TS/TSX files
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v '^scripts/' || true)
if [ -n "$STAGED" ]; then
  if echo "$STAGED" | xargs grep -l "console\.log\|console\.debug" 2>/dev/null; then
    echo "❌ console.log/debug found in staged files. Remove before committing."
    exit 1
  fi
fi

# Block .claude/settings.json from being committed
if git diff --cached --name-only | grep -q "^\.claude/settings\.json$"; then
  echo "❌ .claude/settings.json should not be committed (add to .gitignore)"
  exit 1
fi

echo "✅ pre-commit checks passed"
