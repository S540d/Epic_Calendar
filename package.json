    "@react-native-async-storage/async-storage": "1.23.1",
    "@shopify/react-native-skia": "1.5.0",
    "expo": "~52.0.0",
    "expo-asset": "^56.0.15",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.0",
    "i18next": "^26.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
